# ─── Azure AD (O365 Login) ────────────────────────────────────────────────────
# Azure Portal → App Registrations → New registration
# Set Redirect URI to your app URL (e.g. http://localhost:5173)
VITE_AZURE_AD_CLIENT_ID=your-azure-ad-app-client-id
VITE_AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# Same as above for the backend (token validation)
AZURE_AD_CLIENT_ID=your-azure-ad-app-client-id
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# Admin email addresses (comma-separated) — users with these emails get admin role on first login
ADMIN_EMAILS=admin@yourschool.com

# ─── Azure AI Speech ──────────────────────────────────────────────────────────
# Azure Portal → Create "Speech" resource
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
# Azure Portal → Create "Azure OpenAI" resource → Deploy gpt-4o model
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ─── Azure Cosmos DB ──────────────────────────────────────────────────────────
# Azure Portal → Create "Azure Cosmos DB for NoSQL" resource
# Option A: connection string
AZURE_COSMOS_CONNECTION_STRING=AccountEndpoint=https://your-account.documents.azure.com:443/;AccountKey=xxx==;
# Option B: endpoint + key (used if CONNECTION_STRING is not set)
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOS_KEY=your_cosmos_key_here
AZURE_COSMOS_DB_NAME=english-coach

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
